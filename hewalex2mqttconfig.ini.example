[MQTT]
; IP address of your MQTT broker
MQTT_ip = 192.168.1.100
MQTT_port = 1883
; Set to True if your broker requires authentication
MQTT_authentication = True
MQTT_user = your_mqtt_user
MQTT_pass = your_mqtt_password

[ZPS]
; Solar boiler controller (ZPS) — set Enabled = True to activate
Device_Zps_Enabled = False
Device_Zps_Address = 192.168.1.7
Device_Zps_Port = 8899
Device_Zps_MqttTopic = SolarBoiler

[Pcwu]
; Heat pump controller (PCWU) — set Enabled = True to activate
Device_Pcwu_Enabled = True
; IP address of the RS485-to-TCP gateway (e.g. Waveshare RS485 TO ETH)
Device_Pcwu_Address = 192.168.1.66
Device_Pcwu_Port = 8899
; Base MQTT topic — all state values are published under this topic
Device_Pcwu_MqttTopic = Heatpump
; Serial port settings (must match gateway configuration)
Baudrate = 38400
Bytesize = 8
Parity = NONE
Stopbits = 1
Timeout = 1
; Set to True to enable verbose DEBUG logging in AppDaemon
DebugLogging = False
